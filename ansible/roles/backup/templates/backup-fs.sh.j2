#!/bin/bash
# MediaWiki Filesystem Backup Script

set -euo pipefail

BACKUP_DIR="{{ backup_fs_dir }}"
RETENTION_DAYS="{{ backup_retention_days }}"
MEDIAWIKI_DIR="/var/www/mediawiki"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/mediawiki_fs_${TIMESTAMP}.tar.gz"

echo "[$(date)] Starting filesystem backup..."

# Create tar archive
tar -czf "${BACKUP_FILE}" -C / var/www/mediawiki 2>/dev/null || true

echo "[$(date)] Backup saved to ${BACKUP_FILE}"

# Remove old backups
find "${BACKUP_DIR}" -name "mediawiki_fs_*.tar.gz" -mtime +${RETENTION_DAYS} -delete
echo "[$(date)] Cleaned up backups older than ${RETENTION_DAYS} days"

echo "[$(date)] Filesystem backup completed successfully"
